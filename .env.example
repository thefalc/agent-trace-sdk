# Confluent Cloud Kafka
CONFLUENT_BOOTSTRAP_SERVERS=pkc-xxxxx.us-west-2.aws.confluent.cloud:9092
CONFLUENT_API_KEY=your-kafka-api-key
CONFLUENT_API_SECRET=your-kafka-api-secret

# Confluent Schema Registry
CONFLUENT_SCHEMA_REGISTRY_URL=https://psrc-xxxxx.us-west-2.aws.confluent.cloud
CONFLUENT_SCHEMA_REGISTRY_API_KEY=your-sr-api-key
CONFLUENT_SCHEMA_REGISTRY_API_SECRET=your-sr-api-secret

# Real-Time Context Engine (for dashboard)
RTCE_ORG_ID=your-org-id
RTCE_ENV_ID=env-xxxxx
RTCE_CLUSTER_ID=lkc-xxxxx
RTCE_API_KEY=your-rtce-api-key
RTCE_API_SECRET=your-rtce-api-secret
RTCE_REGION=us-east-1
